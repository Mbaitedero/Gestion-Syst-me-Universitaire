<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DW_GestionUniversitaire">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=JAPHET-ALLAHNDI;Initial Catalog=DW_GestionUniversitaire</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>f4eb22ab-3fc8-489f-a180-275cc7dc2dbd</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DW_GestionUniversitaire</DataSourceName>
        <CommandText>SELECT
    m.libelle AS matiere,
    m.semestre,
    m.coefficient,
    en.nom_complet AS enseignant,
    f.nom_filiere,
    COUNT(DISTINCT fn.id_etudiant_dim) AS nb_etudiants,
    AVG(fn.note_obtenue) AS moyenne,
    COUNT(CASE WHEN fn.note_obtenue &gt;= 10 THEN 1 END) AS nb_reussites,
    CAST(COUNT(CASE WHEN fn.note_obtenue &gt;= 10 THEN 1 END) * 100.0
         / COUNT(fn.id_fait_note) AS DECIMAL(5,2)) AS taux_reussite
FROM FAIT_NOTE fn
JOIN DIM_MATIERE    m  ON fn.id_matiere_dim    = m.id_matiere_dim
JOIN DIM_ENSEIGNANT en ON fn.id_enseignant_dim = en.id_enseignant_dim
JOIN DIM_FILIERE    f  ON fn.id_filiere_dim    = f.id_filiere_dim
GROUP BY m.libelle, m.semestre, m.coefficient, en.nom_complet, f.nom_filiere
ORDER BY taux_reussite ASC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="matiere">
          <DataField>matiere</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="semestre">
          <DataField>semestre</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="coefficient">
          <DataField>coefficient</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="enseignant">
          <DataField>enseignant</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom_filiere">
          <DataField>nom_filiere</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nb_etudiants">
          <DataField>nb_etudiants</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="moyenne">
          <DataField>moyenne</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="nb_reussites">
          <DataField>nb_reussites</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="taux_reussite">
          <DataField>taux_reussite</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
